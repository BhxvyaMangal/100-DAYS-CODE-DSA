/*Perform DFS starting from a given source vertex using recursion.*/
#include <stdio.h>
#include <stdlib.h>

void dfs(int v, int *visited, int **adj, int *sizes) {
    visited[v] = 1;
    printf("%d ", v);
    
    for (int i = 0; i < sizes[v]; i++) {
        int u = adj[v][i];
        if (!visited[u]) {
            dfs(u, visited, adj, sizes);
        }
    }
}

int main() {
    int n;
    scanf("%d", &n);

    int **adj = (int **)malloc(n * sizeof(int *));
    int *sizes = (int *)malloc(n * sizeof(int));

    for (int i = 0; i < n; i++) {
        scanf("%d", &sizes[i]);
        adj[i] = (int *)malloc(sizes[i] * sizeof(int));
        for (int j = 0; j < sizes[i]; j++) {
            scanf("%d", &adj[i][j]);
        }
    }

    int s;
    scanf("%d", &s);

    int *visited = (int *)calloc(n, sizeof(int));

    dfs(s, visited, adj, sizes);

    return 0;
}
