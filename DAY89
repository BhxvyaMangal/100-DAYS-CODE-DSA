/*Given an array of integers where each element represents the number of pages in a book, and m students, allocate books such that each student gets at least one book and the maximum number of pages assigned to a 
student is minimized.*/
def is_possible(arr, n, m, mid):
    students = 1
    pages = 0
    
    for i in range(n):
        if pages + arr[i] <= mid:
            pages += arr[i]
        else:
            students += 1
            pages = arr[i]
            if students > m:
                return False
    return True

def allocate_books(arr, n, m):
    if m > n:
        return -1
    
    low = max(arr)
    high = sum(arr)
    result = high
    
    while low <= high:
        mid = (low + high) // 2
        
        if is_possible(arr, n, m, mid):
            result = mid
            high = mid - 1
        else:
            low = mid + 1
            
    return result

n, m = map(int, input().split())
arr = list(map(int, input().split()))

print(allocate_books(arr, n, m))
