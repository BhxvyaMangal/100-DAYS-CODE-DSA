/*Given weighted undirected graph, compute total weight of Minimum Spanning Tree using Prim’s algorithm.*/
#include <stdio.h>
#include <limits.h>

#define MAX 100

int minKey(int key[], int mst[], int n) {
    int min = INT_MAX, min_index;
    for (int v = 1; v <= n; v++) {
        if (mst[v] == 0 && key[v] < min) {
            min = key[v];
            min_index = v;
        }
    }
    return min_index;
}

int main() {
    int n, m;
    scanf("%d %d", &n, &m);

    int graph[MAX][MAX] = {0};

    for (int i = 0; i < m; i++) {
        int u, v, w;
        scanf("%d %d %d", &u, &v, &w);
        graph[u][v] = w;
        graph[v][u] = w;
    }

    int key[MAX], mst[MAX];

    for (int i = 1; i <= n; i++) {
        key[i] = INT_MAX;
        mst[i] = 0;
    }

    key[1] = 0;

    int total = 0;

    for (int count = 1; count <= n; count++) {
        int u = minKey(key, mst, n);
        mst[u] = 1;
        total += key[u];

        for (int v = 1; v <= n; v++) {
            if (graph[u][v] && mst[v] == 0 && graph[u][v] < key[v]) {
                key[v] = graph[u][v];
            }
        }
    }

    printf("%d\n", total);

    return 0;
}
