/*Find the height (maximum depth) of a given binary tree.*/
int max(int a, int b)
{
    if (a > b)
        return a;
    else
        return b;
}

int maxDepth(struct TreeNode* root)
{
    if (root == NULL)
        return 0;

    int left = maxDepth(root->left);
    int right = maxDepth(root->right);

    return 1 + max(left, right);
}
