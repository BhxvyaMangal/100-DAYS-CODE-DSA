/*Given a queue of integers, reverse the queue using a stack.*/

#include <stdio.h>
#include <stdlib.h>

#define MAX 100

int queue[MAX];
int front = -1, rear = -1;

int stack[MAX];
int top = -1;

void enqueue(int x)
{
    if (rear == MAX - 1)
        return;

    if (front == -1)
        front = 0;

    queue[++rear] = x;
}

int dequeue()
{
    if (front == -1 || front > rear)
        return -1;

    return queue[front++];
}

void push(int x)
{
    stack[++top] = x;
}

int pop()
{
    return stack[top--];
}

void reverseQueue()
{
    while (front <= rear)
    {
        push(dequeue());
    }

    front = 0;
    rear = -1;

    while (top != -1)
    {
        enqueue(pop());
    }
}

void display()
{
    for (int i = front; i <= rear; i++)
        printf("%d ", queue[i]);

    printf("\n");
}

int main()
{
    enqueue(10);
    enqueue(20);
    enqueue(30);
    enqueue(40);

    printf("Original Queue:\n");
    display();

    reverseQueue();

    printf("Reversed Queue:\n");
    display();

    return 0;
}
