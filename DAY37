/*Implement a Priority Queue using an array. An element with smaller value has higher priority.*/
#include <stdio.h>

#define MAX 100

int pq[MAX];
int size = 0;

void insert(int value)
{
    if (size == MAX)
    {
        printf("Queue Overflow\n");
        return;
    }

    pq[size] = value;
    size++;
}

void delete()
{
    if (size == 0)
    {
        printf("Queue Underflow\n");
        return;
    }

    int i, minIndex = 0;

    for (i = 1; i < size; i++)
    {
        if (pq[i] < pq[minIndex])
        {
            minIndex = i;
        }
    }

    printf("Deleted element = %d\n", pq[minIndex]);

    for (i = minIndex; i < size - 1; i++)
    {
        pq[i] = pq[i + 1];
    }

    size--;
}

void display()
{
    if (size == 0)
    {
        printf("Queue is empty\n");
        return;
    }

    for (int i = 0; i < size; i++)
    {
        printf("%d ", pq[i]);
    }
    printf("\n");
}

int main()
{
    insert(30);
    insert(10);
    insert(50);
    insert(20);

    display();

    delete();

    display();

    return 0;
}
