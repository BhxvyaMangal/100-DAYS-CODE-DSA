/*Problem: Evaluate Postfix Expression - Implement using linked list with dynamic memory allocation*/
#include <stdio.h>
#include <stdlib.h>
#include <ctype.h>

struct Node{
    int data;
    struct Node* next;
};

struct Node* top = NULL;

void push(int val){
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->data = val;
    newNode->next = top;
    top = newNode;
}

int pop(){
    if(top == NULL){
        printf("Stack Underflow\n");
        return -1;
    }
    struct Node* temp = top;
    int val = temp->data;
    top = top->next;
    free(temp);
    return val;
}

int evaluatePostfix(char exp[]){
    int i = 0;
    char ch;
    int op1, op2, result;

    while((ch = exp[i]) != '\0'){
        if(isdigit(ch)){
            push(ch - '0');
        }else{
            op2 = pop();
            op1 = pop();

            switch(ch){
                case '+': result = op1 + op2; break;
                case '-': result = op1 - op2; break;
                case '*': result = op1 * op2; break;
                case '/': result = op1 / op2; break;
            }
            push(result);
        }
        i++;
    }
    return pop();
}

int main(){
    char exp[100];

    printf("Enter postfix expression: ");
    scanf("%s", exp);

    int result = evaluatePostfix(exp);

    printf("Result = %d\n", result);

    return 0;
}
